{
  "expo": {
    "name": "Nar Aura",
    "slug": "nar-aura",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDFB",
      "dark": {
        "backgroundColor": "#FFFDFB"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.nar.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Nar Aura, barkod taramak ve yemek fotoğrafı analizi için kameraya ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "Nar Aura, galerideki besin etiketi fotoğraflarını analiz etmek için erişim ister."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFDFB"
      },
      "package": "app.nar.scanner",
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "nar-app",
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      [
        "expo-camera",
        {
          "cameraPermission": "Nar Aura, barkod taramak için kameraya erişim ister."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C73030"
        }
      ],
      "expo-font"
    ]
  }
}
